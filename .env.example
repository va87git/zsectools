# ── SAP NW RFC SDK ──────────────────────────────────────────────────────────
# Path to the SAP NW RFC SDK on the HOST machine (for Docker volume mount)
SAPNWRFC_HOST_PATH=/opt/sap/nwrfcsdk
# Path inside the container where the SDK will be mounted (leave as-is)
SAPNWRFC_CONTAINER_PATH=/opt/sap/nwrfcsdk

# ── SAP NW RFC SDK (Node.js / native) ───────────────────────────────────────
# These must match SAPNWRFC_CONTAINER_PATH
SAPNWRFC_HOME=/opt/sap/nwrfcsdk
LD_LIBRARY_PATH=/opt/sap/nwrfcsdk/lib

# ── Database (Docker internal — change only if you modify docker-compose.yml) ─
DB_HOST=db
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=apppassword

# ── Backend ──────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173
